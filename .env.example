# Database: SQLite (default) or PostgreSQL
# DATABASE_PATH=data/data.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/dior_bot
# TYPEORM_SYNCHRONIZE=false
# NODE_ENV=production

# Webhook (required secret when IS_WEBHOOK is set in production)
# TELEGRAM_WEBHOOK_SECRET=generate-long-random-string
# ADMIN_API_KEY=required-for-automations-api-in-bot.ts

# Commercial marketing pushes (automations promos, growth crons, post-deposit upsell).
# Off by default. Set to 1 only if you explicitly want promo messages.
# COMMERCIAL_PUSH_ENABLED=0

# Reseller API (partners created in bot admin store keys in DB; env JSON is optional)
# RESELLER_API_ENABLED=1
# RESELLER_API_SIGNING_SECRETS_JSON={"reseller-id":"secret-min-12-chars"}
# RESELLER_API_EXPOSE_DOCS=false
# TRUST_PROXY=true
# REDIS_URL=redis://127.0.0.1:6379
# PAYMENT_POLL_MS=15000

# ============================================
# Telegram Bot Configuration
# ============================================
BOT_TOKEN=your_bot_token_from_@BotFather
BOT_USERNAME=@your_bot_username
WEBSITE_URL=https://dior.host/
SUPPORT_USERNAME_TG=@diorhost
# ============================================
# Payment Provider: CrystalPay
# ============================================
PAYMENT_CRYSTALPAY_ID=your_crystalpay_login
PAYMENT_CRYSTALPAY_SECRET_ONE=your_crystalpay_secret_one
PAYMENT_CRYSTALPAY_SECRET_TWO=your_crystalpay_secret_two

# ============================================
# Payment Provider: Crypto Pay — пополнение баланса (кнопка «CryptoBot» в боте)
# ============================================
# Токен приложения: @CryptoBot → Crypto Pay → Мои приложения → [приложение] → API-токен
# Без этого токена способ «CryptoBot» в меню пополнения не будет работать.
# Подойдёт также переменная PAYMENT_CRYPTO_PAY_TOKEN.
# Testnet: @CryptoTestnetBot, URL https://testnet-pay.crypt.bot/api
PAYMENT_CRYPTOBOT_TOKEN=your_cryptobot_app_token

# Цена продления Dedicated по умолчанию (USD), если у сервера не задана monthlyPrice.
# Используется для кнопки «Оплатить» в карточке выделенного сервера.
# DEDICATED_DEFAULT_MONTHLY_PRICE=50

# ============================================
# VMManager API
# ============================================
# Провайдер VM: vmmanager | proxmox
# VM_PROVIDER=vmmanager
VMM_EMAIL=your_email@example.com
VMM_PASSWORD=your_vmm_password
VMM_ENDPOINT_URL=https://your-vmm-endpoint.com/
# Optional: restrict VPS OS picker to specific VMmanager template IDs (comma-separated).
# Leave unset to show all active catalog templates (ubuntu2404, centosstream9, …).
# VMM_ALLOWED_OS_IDS=
# ============================================
# Proxmox API (если VM_PROVIDER=proxmox)
# ============================================
# PROXMOX_BASE_URL=https://your-proxmox-host:8006
# PROXMOX_NODE=pve01
# PROXMOX_TOKEN_ID=api-user@pam!bot
# PROXMOX_TOKEN_SECRET=your-secret
# PROXMOX_STORAGE=local-lvm
# PROXMOX_BRIDGE=vmbr0
# Shared IPv4 registry — optional, SAME database as dior-billing (off by default for TG bot)
# PROXMOX_USE_SHARED_IP_REGISTRY=0
# SHARED_IP_DATABASE_URL=mysql://billing_user:pass@127.0.0.1:3306/dior_billing
# BILLING_DATABASE_URL=mysql://billing_user:pass@127.0.0.1:3306/dior_billing
# PROXMOX_REQUIRE_SHARED_IP_REGISTRY=0
# PROXMOX_NETWORK=45.74.7.0/24
# PROXMOX_GATEWAY=45.74.7.1
# PROXMOX_IP_START=100
# PROXMOX_IP_END=250
# PROXMOX_NAMESERVER=1.1.1.1
# PROXMOX_RESERVED_IPS=45.74.7.2,45.74.7.252
# Map shop locations to Proxmox nodes (required for USA/DE/TR auto-provision; NL uses PROXMOX_NODE by default)
# PROXMOX_LOCATION_NODES_JSON={"nl-amsterdam":"pve01","usa":"pve-usa","de-germany":"pve-de","tr-istanbul":"pve-tr"}
# PROXMOX_LOCATION_BRIDGES_JSON={"usa":"vmbr0","de-germany":"vmbr0"}
# PROXMOX_LOCATION_STORAGE_JSON={"usa":"local-lvm"}
# PROXMOX_INSECURE_TLS=0
# Optional override: merges on top of src/config/proxmox-templates.json (committed defaults).
# Use only if a VMID differs on your cluster — secrets stay in .env, template IDs are in git.
# PROXMOX_TEMPLATE_MAP={"winserver2019":106}

# ============================================
# Prime Subscription — 7-day free trial via channel
# ============================================
# Ссылка на канал (кнопка «Перейти и подписаться»). По умолчанию: https://t.me/+C27tBPXXpj40ZGE6
# PRIME_CHANNEL_INVITE=https://t.me/+C27tBPXXpj40ZGE6
#
# Для проверки подписки при нажатии «Я подписался» обязателен один из двух вариантов (без этого будет ошибка «Проверка подписки пока не настроена»):
# — Приватный канал (как t.me/+xxx): числовой ID канала. Бот должен быть админом. ID: добавь @userinfobot в канал или перешли сообщение из канала боту @getidsbot.
# PRIME_CHANNEL_ID=-1001234567890
# — Публичный канал: username без @
# PRIME_CHANNEL_USERNAME=diorhost_news

# ============================================
# Amper Domains API — покупка доменов в боте
# ============================================
# Документация: https://amper.lat/api/v1/docs
# Без этих переменных раздел «Домены» и регистрация через Amper недоступны.
#
# Формат заголовка для запросов: Authorization: ApiKey sk_live_...
# В .env задаётся только ключ (sk_live_...); префикс "ApiKey " добавляется в коде.
AMPER_API_BASE_URL=https://amper.lat
AMPER_API_TOKEN=sk_live_your_amper_api_key
# Таймаут запросов (мс). По умолчанию 8000
# AMPER_API_TIMEOUT_MS=8000

# ============================================
# CDN / Прокси сайтов (proxy-service Bot API)
# ============================================
# Без этих переменных кнопка «CDN» в меню отображается, но при нажатии будет «Услуга CDN пока не подключена».
# CDN_BASE_URL=https://your-proxy-service.com
# CDN_BOT_API_KEY=your-bot-api-key-from-proxy-service-env
# Дефолтный origin для кнопки «Подобрать автоматически» (должен отличаться от домена CDN клиента)
# Пример: CDN_AUTO_TARGET_URL=http://127.0.0.1:3000
# CDN_AUTO_TARGET_URL=
# Если create-proxy на стороне CDN ожидает snake_case в JSON-теле — установите 1
# CDN_BOT_CREATE_PROXY_SNAKE=1
# AMPER_FAKE_AVAILABLE=1  — для теста: считать домен доступным и доходить до шага регистрации (при нулевом балансе Amper регистрация вернёт ошибку, средства вернут)
# Дефолтные NS, если пользователь не указал (опционально)
# DEFAULT_NS1=ns1.example.com
# DEFAULT_NS2=ns2.example.com

# ============================================
# Domain Checker (опционально)
# ============================================
DOMAINR_TOKEN=your_domainr_token

# ============================================
# Webhook Configuration (опционально)
# ============================================
# IS_WEBHOOK=https://your-domain.com/webhook
# PORT_WEBHOOK=8443
# Long polling: health + POST /api/admin/billing/notify (defaults to 8443 when ADMIN_API_KEY is set)

# Список Telegram ID администраторов (через запятую). Эти пользователи получают доступ к админ-панели даже без роли admin в БД.
# ADMIN_TELEGRAM_IDS=7568177886,123456789

# Чат для операционных алертов (тикеты VPS/dedicated, выводы и т.д.): ID группы (отрицательный) или личка админа.
# Не сбрасывается при перезапуске PM2 (в отличие от авто-запоминания последнего чата модератора).
# STAFF_NOTIFY_CHAT_ID=-1001234567890

# Для Admin UI (automations): разрешённый origin для CORS (по умолчанию *)
# CORS_ORIGIN=https://admin.example.com
# Ключ API: если задан, запросы к /api/admin/automations должны содержать заголовок X-Admin-API-Key или Authorization: Bearer <key>
# ADMIN_API_KEY=your-secret-admin-api-key

# ============================================
# Reseller API (optional)
# ============================================
# Enable separate reseller API server
# RESELLER_API_ENABLED=1
# RESELLER_API_PORT=3003
# JSON map: reseller_id -> api_key
# Example:
# RESELLER_API_KEYS_JSON={"partner_a":"replace-with-strong-secret-key"}
# Optional request HMAC secrets (same reseller_id keys). If set, client must send:
# x-timestamp: unix seconds
# x-signature: hex(HMAC_SHA256(secret, "<timestamp>.<raw_json_body>"))
# RESELLER_API_SIGNING_SECRETS_JSON={"partner_a":"hmac-secret-32-chars-min"}
# Per-partner: x-api-key only, no HMAC (balance + rate limits + maxVps still enforced)
# RESELLER_API_KEY_ONLY_JSON={"partner_a":true}
# Optional allowlist by reseller_id (exact IPv4 match)
# RESELLER_API_ALLOWED_IPS_JSON={"partner_a":["203.0.113.10","198.51.100.20"]}
# Optional webhooks per reseller_id (service lifecycle events)
# RESELLER_WEBHOOKS_JSON={"partner_a":"https://partner-a.com/webhooks/dior"}
# Optional webhook signing secrets for outbound callbacks (same signature scheme)
# RESELLER_WEBHOOK_SECRETS_JSON={"partner_a":"webhook-hmac-secret"}
# Rate limit per reseller key
# RESELLER_API_RATE_WINDOW_SEC=60
# RESELLER_API_RATE_MAX=120
# Signature timestamp skew tolerance (seconds)
# RESELLER_API_MAX_SKEW_SECONDS=300
# Idempotency response cache TTL (seconds) for POST retries
# RESELLER_API_IDEMPOTENCY_TTL_SEC=3600
# Strongly recommended in production: shared idempotency + nonce store (else single-process RAM only)
# REDIS_URL=redis://127.0.0.1:6379
# After VM create, poll hypervisor until IPv4 is assigned (defaults: 20 tries × 2000 ms)
# RESELLER_VDS_IP_POLL_MAX_ATTEMPTS=20
# RESELLER_VDS_IP_POLL_MS=2000
# Scope: each reseller sees/controls only services with matching resellerId

# ============================================
# Growth (upsell, reactivation, FOMO, trigger)
# ============================================
# Опционально. Без Redis офферы хранятся в памяти (до перезапуска).
# REDIS_URL=redis://localhost:6379

# ============================================
# Feature toggles
# ============================================
# VPS/VDS в меню «Услуги» и «Управление услугами» скрыты по умолчанию. Показать: SHOW_VPS_VDS_IN_MENUS=1
# SHOW_VPS_VDS_IN_MENUS=1

# ============================================
# Environment
# ============================================
NODE_ENV=production

# Публичный канал — username без @ (рекомендуется)
PRIME_CHANNEL_USERNAME=your_channel_username
# Для приватного канала — числовой ID с префиксом -100
# PRIME_CHANNEL_ID=-1001234567890