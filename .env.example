# ============================================
# Amper Domains API — покупка доменов в боте
# ============================================
# Документация: https://amper.lat/api/v1/docs
# Без этих переменных раздел «Домены» и регистрация через Amper недоступны.
#
# Формат заголовка для запросов: Authorization: ApiKey sk_live_...
# В .env задаётся только ключ (sk_live_...); префикс "ApiKey " добавляется в коде.
AMPER_API_BASE_URL=https://amper.lat/api/v1/docs
AMPER_API_TOKEN=sk_live_ee6a26c5ce72674e9822bb576e9b3fffd06d37a178c509f2
# Таймаут запросов (мс). По умолчанию 8000
# AMPER_API_TIMEOUT_MS=8000

# ============================================
# CDN / Прокси сайтов (proxy-service Bot API)
# ============================================
# Без этих переменных кнопка «CDN» в меню отображается, но при нажатии будет «Услуга CDN пока не подключена».
# CDN_BASE_URL=https://your-proxy-service.com
# CDN_BOT_API_KEY=your-bot-api-key-from-proxy-service-env
# Дефолтный origin для кнопки «Подобрать автоматически» (должен отличаться от домена CDN клиента)
# Пример: CDN_AUTO_TARGET_URL=http://127.0.0.1:3000
# CDN_AUTO_TARGET_URL=
# Если create-proxy на стороне CDN ожидает snake_case в JSON-теле — установите 1
# CDN_BOT_CREATE_PROXY_SNAKE=1
# AMPER_FAKE_AVAILABLE=1  — для теста: считать домен доступным и доходить до шага регистрации (при нулевом балансе Amper регистрация вернёт ошибку, средства вернут)
# Дефолтные NS, если пользователь не указал (опционально)
# DEFAULT_NS1=ns1.example.com
# DEFAULT_NS2=ns2.example.com

# ============================================
# Domain Checker (опционально)
# ============================================
DOMAINR_TOKEN=your_domainr_token

# ============================================
# Webhook Configuration (опционально)
# ============================================
# IS_WEBHOOK=https://your-domain.com/webhook
# PORT_WEBHOOK=3002

# Список Telegram ID администраторов (через запятую). Эти пользователи получают доступ к админ-панели даже без роли admin в БД.
# ADMIN_TELEGRAM_IDS=7568177886,123456789

# Для Admin UI (automations): разрешённый origin для CORS (по умолчанию *)
# CORS_ORIGIN=https://admin.example.com
# Ключ API: если задан, запросы к /api/admin/automations должны содержать заголовок X-Admin-API-Key или Authorization: Bearer <key>
# ADMIN_API_KEY=your-secret-admin-api-key

# ============================================
# Reseller API (optional)
# ============================================
# Enable separate reseller API server
# RESELLER_API_ENABLED=1
# RESELLER_API_PORT=3003
# JSON map: reseller_id -> api_key
# Example:
# RESELLER_API_KEYS_JSON={"partner_a":"replace-with-strong-secret-key"}
# Optional request HMAC secrets (same reseller_id keys). If set, client must send:
# x-timestamp: unix seconds
# x-signature: hex(HMAC_SHA256(secret, "<timestamp>.<raw_json_body>"))
# RESELLER_API_SIGNING_SECRETS_JSON={"partner_a":"hmac-secret-32-chars-min"}
# Optional allowlist by reseller_id (exact IPv4 match)
# RESELLER_API_ALLOWED_IPS_JSON={"partner_a":["203.0.113.10","198.51.100.20"]}
# Optional webhooks per reseller_id (service lifecycle events)
# RESELLER_WEBHOOKS_JSON={"partner_a":"https://partner-a.com/webhooks/dior"}
# Optional webhook signing secrets for outbound callbacks (same signature scheme)
# RESELLER_WEBHOOK_SECRETS_JSON={"partner_a":"webhook-hmac-secret"}
# Rate limit per reseller key
# RESELLER_API_RATE_WINDOW_SEC=60
# RESELLER_API_RATE_MAX=120
# Signature timestamp skew tolerance (seconds)
# RESELLER_API_MAX_SKEW_SECONDS=300
# Idempotency response cache TTL (seconds) for POST retries
# RESELLER_API_IDEMPOTENCY_TTL_SEC=3600
# Scope: each reseller sees/controls only services with matching resellerId

# ============================================
# Growth (upsell, reactivation, FOMO, trigger)
# ============================================
# Опционально. Без Redis офферы хранятся в памяти (до перезапуска).
# REDIS_URL=redis://localhost:6379

# ============================================
# Feature toggles
# ============================================
# VPS/VDS в меню «Услуги» и «Управление услугами» скрыты по умолчанию. Показать: SHOW_VPS_VDS_IN_MENUS=1
# SHOW_VPS_VDS_IN_MENUS=1

