# Proxmox VM disk resize (example env — copy to `.env` or merge with your app)
#
# Required
PROXMOX_BASE_URL=https://pve.example.com:8006
PROXMOX_NODE=pve01
PROXMOX_TOKEN_ID=api-user@pam!bot-token-name
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# Optional — TLS to PVE with self-signed / internal CA
PROXMOX_INSECURE_TLS=1
#
# Optional — tuning
PROXMOX_HTTP_TIMEOUT_MS=120000
PROXMOX_RESIZE_MAX_RETRIES=3
PROXMOX_RESIZE_RETRY_BASE_DELAY_MS=500
#
# Primary HTTP method: PUT (as in your curl spec) or POST (common on stock Proxmox VE)
PROXMOX_DISK_RESIZE_HTTP_METHOD=PUT
#
# If primary returns 405/501, automatically retry with the other verb (recommended in production)
PROXMOX_DISK_RESIZE_FALLBACK_METHOD=1
